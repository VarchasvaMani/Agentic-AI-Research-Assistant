# ─────────────────────────────────────────────────────────────────
#  Agentic RAG Research Assistant — Config
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── LLM Backend ───────────────────────────────────────────────────
#
#  Choose ONE of two options:
#
#  Option A — Anthropic Claude (best quality, requires API key)
#    LLM_BACKEND=anthropic
#    Get your key at: https://console.anthropic.com
#
#  Option B — Ollama (free, runs locally, no API key needed)
#    LLM_BACKEND=ollama
#    Install Ollama: https://ollama.com
#    Then pull a model:
#      ollama pull llama3    # best quality (~5 GB RAM)
#      ollama pull mistral   # balanced    (~4 GB RAM)
#      ollama pull phi3      # lightest    (~2 GB RAM)
#
LLM_BACKEND=anthropic

# ── Anthropic settings (only used when LLM_BACKEND=anthropic) ─────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Ollama settings (only used when LLM_BACKEND=ollama) ───────────
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── ChromaDB ──────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=research_docs

# ── Chunking ──────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ── Retrieval ─────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5

# ── Agent ─────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=8

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=INFO
